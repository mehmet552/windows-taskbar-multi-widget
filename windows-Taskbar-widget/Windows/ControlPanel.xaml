<Window x:Class="TaskbarMusicWidget.Windows.ControlPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Widget Control Panel" Height="500" Width="480"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        ShowInTaskbar="True">
    <Border Background="#121212" CornerRadius="16" BorderBrush="#333333" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="4" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0" MouseLeftButtonDown="Header_MouseDown" Cursor="SizeAll">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E1A34" Offset="0"/>
                        <GradientStop Color="#0F172A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="24,20,24,20">
                    <StackPanel>
                        <TextBlock Text="⚙️ Configuration" Foreground="White"
                                   FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Personalize your widgets and settings" Foreground="#94A3B8" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="Close_Click" Background="Transparent" BorderThickness="0"
                            Foreground="#94A3B8" FontSize="16" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,20">

                    <!-- Section: Visualizer Settings -->
                    <TextBlock Text="VISUALIZATION" Foreground="#38BDF8" FontSize="11"
                               FontWeight="Bold" Margin="0,0,0,12" />

                    <Border Background="#1E2024" CornerRadius="12" Padding="16,14" BorderBrush="#2D3035" BorderThickness="1" Margin="0,0,0,24">
                        <Grid>
                            <TextBlock Text="Music Visualizer Style" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox Name="CmbVisualizerStyle" HorizontalAlignment="Right" VerticalAlignment="Center" Width="140"
                                      SelectionChanged="VisualizerStyle_Changed" Height="26">
                                <ComboBoxItem Content="Bars (Up/Down)"/>
                                <ComboBoxItem Content="Sound Wave"/>
                                <ComboBoxItem Content="Walking Cat"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Section: App Settings -->
                    <TextBlock Text="BEHAVIOR" Foreground="#38BDF8" FontSize="11"
                               FontWeight="Bold" Margin="0,0,0,12" />

                    <Border Background="#1E2024" CornerRadius="12" Padding="16,14" BorderBrush="#2D3035" BorderThickness="1" Margin="0,0,0,24">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Start automatically with Windows" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                <CheckBox Name="ChkStartup" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Checked="Startup_Changed" Unchecked="Startup_Changed">
                                    <CheckBox.LayoutTransform>
                                        <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                                    </CheckBox.LayoutTransform>
                                </CheckBox>
                            </Grid>
                            <Border Height="1" Background="#2D3035" Margin="0,14,0,14"/>
                            <Grid>
                                <TextBlock Text="Hide on full-screen apps (e.g. Games)" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                <CheckBox Name="ChkHideFullScreen" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Checked="HideFullScreen_Changed" Unchecked="HideFullScreen_Changed">
                                    <CheckBox.LayoutTransform>
                                        <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                                    </CheckBox.LayoutTransform>
                                </CheckBox>
                            </Grid>
                            <Border Height="1" Background="#2D3035" Margin="0,14,0,14"/>
                            <Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Taskbar Position" Foreground="White" FontSize="13"/>
                                    <TextBlock Text="0% = Left, 100% = Right" Foreground="#64748B" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Slider Name="SldPosition" Minimum="0" Maximum="100" Width="140" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        ValueChanged="Position_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Section: Widgets -->
                    <TextBlock Text="ACTIVE WIDGETS" Foreground="#38BDF8" FontSize="11"
                               FontWeight="Bold" Margin="0,0,0,12" />

                    <ItemsControl Name="WidgetList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E2024" CornerRadius="12" Margin="0,0,0,10"
                                        Padding="16,12" BorderBrush="#2D3035" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="20"
                                                   VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                            <TextBlock Text="{Binding Name}" Foreground="White"
                                                       FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Description}" Foreground="#94A3B8"
                                                       FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Up/Down buttons -->
                                            <Button Content="▲" Tag="{Binding Id}" Click="MoveUp_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#94A3B8" FontSize="14" Cursor="Hand" Padding="6,4">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="▼" Tag="{Binding Id}" Click="MoveDown_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#94A3B8" FontSize="14" Cursor="Hand" Padding="6,4">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <!-- Toggle -->
                                            <CheckBox IsChecked="{Binding IsEnabled}" Tag="{Binding Id}"
                                                      Checked="Widget_Checked" Unchecked="Widget_Unchecked"
                                                      VerticalAlignment="Center" Margin="12,0,0,0">
                                                <CheckBox.LayoutTransform>
                                                    <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                                                </CheckBox.LayoutTransform>
                                            </CheckBox>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#17191C" CornerRadius="0,0,16,16" Padding="24,16" BorderBrush="#2D3035" BorderThickness="1,0,1,1">
                <Grid>
                    <TextBlock Name="TxtStatus" Foreground="#10B981" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="Done" Click="Save_Click" HorizontalAlignment="Right"
                            Background="#38BDF8" Foreground="White" BorderThickness="0"
                            Padding="24,10" Cursor="Hand" FontSize="13" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
