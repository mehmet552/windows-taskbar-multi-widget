<Window x:Class="TaskbarMusicWidget.Windows.ControlPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Widget Control Panel" Height="400" Width="460"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        ShowInTaskbar="True">
    <Border Background="#111111" CornerRadius="14" BorderBrush="#2A2A2A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.9" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" MouseLeftButtonDown="Header_MouseDown" Cursor="SizeAll">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A0A2E" Offset="0"/>
                        <GradientStop Color="#0F3460" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="22,16,22,16">
                    <StackPanel>
                        <TextBlock Text="⚙️ Control Panel" Foreground="White"
                                   FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="Manage and customize widgets" Foreground="#88AABB" FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="Close_Click" Background="Transparent" BorderThickness="0"
                            Foreground="#666" FontSize="16" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,16,22,16">

                    <!-- Section: Widgets -->
                    <TextBlock Text="WIDGETS" Foreground="#4A9EFF" FontSize="10"
                               FontWeight="Bold" Margin="0,0,0,10"/>


                    <!-- Widget rows -->
                    <ItemsControl Name="WidgetList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#181818" CornerRadius="10" Margin="0,0,0,8"
                                        Padding="14,10" BorderBrush="#252525" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="18"
                                                   VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                            <TextBlock Text="{Binding Name}" Foreground="White"
                                                       FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Description}" Foreground="#555"
                                                       FontSize="10"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Up/Down buttons -->
                                            <Button Content="▲" Tag="{Binding Id}" Click="MoveUp_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#555" FontSize="11" Cursor="Hand" Padding="4,2"/>
                                            <Button Content="▼" Tag="{Binding Id}" Click="MoveDown_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#555" FontSize="11" Cursor="Hand" Padding="4,2"/>
                                            <!-- Toggle -->
                                            <CheckBox IsChecked="{Binding IsEnabled}" Tag="{Binding Id}"
                                                      Checked="Widget_Checked" Unchecked="Widget_Unchecked"
                                                      VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>


                    <Border Height="1" Background="#222" Margin="0,16,0,16"/>

                    <!-- Section: App settings -->
                    <TextBlock Text="APP SETTINGS" Foreground="#888" FontSize="10"
                               FontWeight="Bold" Margin="0,0,0,12"/>


                    <Border Background="#181818" CornerRadius="10" Padding="16,12" BorderBrush="#252525" BorderThickness="1">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Start with Windows" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                <CheckBox Name="ChkStartup" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Checked="Startup_Changed" Unchecked="Startup_Changed"/>
                            </Grid>
                            <Grid Margin="0,12,0,0">
                                <TextBlock Text="Hide on full screen apps" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                <CheckBox Name="ChkHideFullScreen" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Checked="HideFullScreen_Changed" Unchecked="HideFullScreen_Changed"/>
                            </Grid>
                            <Grid Margin="0,12,0,0">
                                <TextBlock Text="Widget Position (%)" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                <Slider Name="SldPosition" Minimum="0" Maximum="100" Width="120" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        ValueChanged="Position_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#141414" CornerRadius="0,0,14,14" Padding="22,12">
                <Grid>
                    <TextBlock Name="TxtStatus" Foreground="#555" FontSize="10" VerticalAlignment="Center"/>
                    <Button Content="Save" Click="Save_Click" HorizontalAlignment="Right"
                            Background="#4A9EFF" Foreground="White" BorderThickness="0"
                            Padding="20,8" Cursor="Hand" FontSize="12" FontWeight="SemiBold">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
