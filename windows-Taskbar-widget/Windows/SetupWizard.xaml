<Window x:Class="TaskbarMusicWidget.Windows.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Taskbar Widget Collection — Setup" Height="440" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        ShowInTaskbar="True">
    <Border Background="#111111" CornerRadius="14" BorderBrush="#2A2A2A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.9" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header bar with gradient accent -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" MouseLeftButtonDown="Header_MouseDown" Cursor="SizeAll">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1A0A2E" Offset="0"/>
                        <GradientStop Color="#16213E" Offset="0.5"/>
                        <GradientStop Color="#0F3460" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="24,20,24,20">
                    <StackPanel>
                        <TextBlock Text="🧩 Widget Collection" Foreground="White"
                                   FontSize="18" FontWeight="Bold"/>
                        <TextBlock Name="TxtSubtitle" Text="Which widgets do you want to use?"
                                   Foreground="#88AABB" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <!-- Step indicator -->
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <Ellipse Name="Dot1" Width="8" Height="8" Fill="#4A9EFF" Margin="3,0"/>
                        <Ellipse Name="Dot2" Width="8" Height="8" Fill="#2A3A4A" Margin="3,0"/>
                        <Ellipse Name="Dot3" Width="8" Height="8" Fill="#2A3A4A" Margin="3,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Page 1: Widget Selection -->
            <StackPanel Name="Page1" Grid.Row="1" Margin="24,16">
                <TextBlock Text="Select widgets" Foreground="#888888" FontSize="11" Margin="0,0,0,12"/>

                <!-- Music -->
                <Border Name="CardMusic" Background="#181818" CornerRadius="10" Margin="0,0,0,8" Padding="16,12"
                        BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="Card_Click" Tag="Music">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🎵" FontSize="22" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Music" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Show and control currently playing music" Foreground="#666" FontSize="10"/>
                        </StackPanel>
                        <CheckBox Name="ChkMusic" Grid.Column="2" IsChecked="True"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"
                                  IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <!-- Timer -->
                <Border Name="CardTimer" Background="#181818" CornerRadius="10" Margin="0,0,0,8" Padding="16,12"
                        BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="Card_Click" Tag="Timer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⏱" FontSize="22" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Timer" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Countdown (right-click to set time)" Foreground="#666" FontSize="10"/>
                        </StackPanel>
                        <CheckBox Name="ChkTimer" Grid.Column="2" IsChecked="True"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"
                                  IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <!-- Stopwatch -->
                <Border Name="CardStopwatch" Background="#181818" CornerRadius="10" Margin="0,0,0,8" Padding="16,12"
                        BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="Card_Click" Tag="Stopwatch">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⏱" FontSize="22" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Stopwatch" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Precision timer and lap tracking" Foreground="#666" FontSize="10"/>
                        </StackPanel>
                        <CheckBox Name="ChkStopwatch" Grid.Column="2" IsChecked="True"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"
                                  IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <!-- Pomodoro -->
                <Border Name="CardPomodoro" Background="#181818" CornerRadius="10" Padding="16,12"
                        BorderBrush="#2A2A2A" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="Card_Click" Tag="Pomodoro">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🍅" FontSize="22" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Pomodoro" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="25/5/15 min focus + break cycle" Foreground="#666" FontSize="10"/>
                        </StackPanel>
                        <CheckBox Name="ChkPomodoro" Grid.Column="2" IsChecked="True"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"
                                  IsHitTestVisible="False"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Page 2: Done -->
            <StackPanel Name="Page2" Grid.Row="1" Margin="24,32" Visibility="Collapsed">
                <TextBlock Text="🎉" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Ready!" Foreground="White" FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,12,0,8"/>
                <TextBlock Text="Your widgets will appear on the taskbar.&#10;You can always access settings by right-clicking the system tray."
                           Foreground="#888" FontSize="12" HorizontalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Background="#141414" CornerRadius="0,0,14,14" Padding="24,14">
                <Grid>
                    <Button Name="BtnBack" Content="← Back" Click="BtnBack_Click"
                            Visibility="Collapsed" HorizontalAlignment="Left"
                            Background="Transparent" Foreground="#888" BorderBrush="#333"
                            BorderThickness="1" Padding="14,7" Cursor="Hand" FontSize="12"/>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button Name="BtnNext" Content="Next →" Click="BtnNext_Click"
                                Background="#4A9EFF" Foreground="White" BorderThickness="0"
                                Padding="18,8" Cursor="Hand" FontSize="12" FontWeight="SemiBold">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
