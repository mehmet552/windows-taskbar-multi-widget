<Window x:Class="TaskbarMusicWidget.Windows.PomodoroSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pomodoro Settings" Height="220" Width="360"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Background="#1E1E1E" CornerRadius="12" BorderBrush="#3A3A3A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.8" Color="Black"/>
        </Border.Effect>
        <StackPanel Margin="20">
            <TextBlock Text="Pomodoro Settings" Foreground="White" FontSize="14"
                       FontWeight="SemiBold" Margin="0,0,0,16"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Text="Work" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Short Break" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Long Break" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Cycles" Foreground="#888" FontSize="9" HorizontalAlignment="Center"/>

                <TextBox Name="TxtWork" Grid.Column="0" Grid.Row="1" Margin="4,6,4,0"
                         Background="#2A2A2A" Foreground="White" BorderBrush="#444"
                         BorderThickness="1" TextAlignment="Center" FontSize="14"
                         FontWeight="Bold" Padding="4" Text="25"
                         PreviewTextInput="NumberOnly_PreviewTextInput"/>
                <TextBox Name="TxtShort" Grid.Column="1" Grid.Row="1" Margin="4,6,4,0"
                         Background="#2A2A2A" Foreground="White" BorderBrush="#444"
                         BorderThickness="1" TextAlignment="Center" FontSize="14"
                         FontWeight="Bold" Padding="4" Text="5"
                         PreviewTextInput="NumberOnly_PreviewTextInput"/>
                <TextBox Name="TxtLong" Grid.Column="2" Grid.Row="1" Margin="4,6,4,0"
                         Background="#2A2A2A" Foreground="White" BorderBrush="#444"
                         BorderThickness="1" TextAlignment="Center" FontSize="14"
                         FontWeight="Bold" Padding="4" Text="15"
                         PreviewTextInput="NumberOnly_PreviewTextInput"/>
                <TextBox Name="TxtCycles" Grid.Column="3" Grid.Row="1" Margin="4,6,4,0"
                         Background="#2A2A2A" Foreground="White" BorderBrush="#444"
                         BorderThickness="1" TextAlignment="Center" FontSize="14"
                         FontWeight="Bold" Padding="4" Text="4"
                         PreviewTextInput="NumberOnly_PreviewTextInput"/>
            </Grid>

            <TextBlock Name="TxtError" Foreground="#EF4444" FontSize="10" Margin="0,8,0,0" Visibility="Collapsed"/>

            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancel" Click="Cancel_Click" Margin="0,0,6,0"
                        Background="#2A2A2A" Foreground="#888" BorderBrush="#444"
                        BorderThickness="1" Padding="8,6" Cursor="Hand"/>
                <Button Grid.Column="1" Content="OK" Click="Ok_Click" Margin="6,0,0,0"
                        Background="#EF4444" Foreground="White" BorderThickness="0"
                        Padding="8,6" Cursor="Hand" FontWeight="SemiBold"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
