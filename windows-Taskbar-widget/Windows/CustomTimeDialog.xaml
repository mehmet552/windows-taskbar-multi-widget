<Window x:Class="TaskbarMusicWidget.Windows.CustomTimeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Time" Height="200" Width="300"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Background="#1E1E1E" CornerRadius="12" BorderBrush="#3A3A3A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.8" Color="Black"/>
        </Border.Effect>
        <StackPanel Margin="20">
            <TextBlock Text="Set Custom Time" Foreground="White" FontSize="14"
                       FontWeight="SemiBold" Margin="0,0,0,16"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Hours" Foreground="#888" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBox Name="TxtHours" Text="0" FontSize="18" FontWeight="Bold"
                             Foreground="White" Background="#2A2A2A" BorderBrush="#444"
                             BorderThickness="1" TextAlignment="Center" Padding="4"
                             PreviewTextInput="NumberOnly_PreviewTextInput"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text=":" Foreground="#666" FontSize="20"
                           VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,8,0,0"/>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Minutes" Foreground="#888" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBox Name="TxtMinutes" Text="5" FontSize="18" FontWeight="Bold"
                             Foreground="White" Background="#2A2A2A" BorderBrush="#444"
                             BorderThickness="1" TextAlignment="Center" Padding="4"
                             PreviewTextInput="NumberOnly_PreviewTextInput"/>
                </StackPanel>

                <TextBlock Grid.Column="3" Text=":" Foreground="#666" FontSize="20"
                           VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,8,0,0"/>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Seconds" Foreground="#888" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBox Name="TxtSeconds" Text="0" FontSize="18" FontWeight="Bold"
                             Foreground="White" Background="#2A2A2A" BorderBrush="#444"
                             BorderThickness="1" TextAlignment="Center" Padding="4"
                             PreviewTextInput="NumberOnly_PreviewTextInput"/>
                </StackPanel>
            </Grid>

            <TextBlock Name="TxtError" Foreground="#EF4444" FontSize="10" Margin="0,8,0,0" Visibility="Collapsed"/>

            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancel" Click="Cancel_Click" Margin="0,0,6,0"
                        Background="#2A2A2A" Foreground="#888" BorderBrush="#444"
                        BorderThickness="1" Padding="8,6" Cursor="Hand"/>
                <Button Grid.Column="1" Content="OK" Click="Ok_Click" Margin="6,0,0,0"
                        Background="#F59E0B" Foreground="Black" BorderThickness="0"
                        Padding="8,6" Cursor="Hand" FontWeight="SemiBold"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
