<Window x:Class="TaskbarMusicWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskbarWidgets"
        Height="40" Width="340"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Navigation arrow button style -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#50FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Name="MainBorder"
            CornerRadius="6"
            Margin="1"
            Background="#1A1A1A">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.6" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="14"/>
            </Grid.ColumnDefinitions>

            <!-- Left navigation arrow -->
            <Button Name="BtnPrevWidget"
                    Grid.Column="0"
                    Content="◀"
                    Style="{StaticResource NavBtn}"
                    Click="BtnPrevWidget_Click"
                    ToolTip="Previous Widget"
                    Visibility="Collapsed"/>

            <!-- Active widget host -->
            <ContentControl Name="WidgetHost"
                            Grid.Column="1"
                            VerticalAlignment="Stretch"/>

            <!-- Right navigation arrow -->
            <Button Name="BtnNextWidget"
                    Grid.Column="2"
                    Content="▶"
                    Style="{StaticResource NavBtn}"
                    Click="BtnNextWidget_Click"
                    ToolTip="Next Widget"
                    Visibility="Collapsed"/>

            <!-- Music Visualizer Indicator -->
            <Border Name="VisualizerContainer"
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"
                    ToolTip="Playing Music"
                    Margin="2,0,0,0">
                <Grid Height="16" Width="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="2"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="2"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Name="VisBar1" Grid.Column="0" Fill="White" VerticalAlignment="Bottom" Height="2" RadiusX="1" RadiusY="1"/>
                    <Rectangle Name="VisBar2" Grid.Column="2" Fill="White" VerticalAlignment="Bottom" Height="2" RadiusX="1" RadiusY="1"/>
                    <Rectangle Name="VisBar3" Grid.Column="4" Fill="White" VerticalAlignment="Bottom" Height="2" RadiusX="1" RadiusY="1"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>