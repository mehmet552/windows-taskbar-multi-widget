<UserControl x:Class="TaskbarMusicWidget.Widgets.MusicWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="38">
    <UserControl.Resources>
        <Style x:Key="MediaBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#60FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="36"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="74"/>
            <ColumnDefinition Width="24"/>
        </Grid.ColumnDefinitions>

        <!-- Album Art (click → toggle drawer) -->
        <Border Grid.Column="0" CornerRadius="4,0,0,4" ClipToBounds="True"
                Cursor="Hand" Margin="3"
                MouseLeftButtonUp="AlbumArt_Click"
                ToolTip="Çekmeceyi Aç / Kapat">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#3D3D3D" Offset="0"/>
                    <GradientStop Color="#2D2D2D" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Image x:Name="AlbumArt" Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock x:Name="NoArtIcon" Text="&#9835;" FontSize="16"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#555555"/>
            </Grid>
        </Border>

        <!-- Title + Artist (scrolling) -->
        <Border Grid.Column="1" ClipToBounds="True"
                VerticalAlignment="Center" Margin="4,0,2,0">
            <StackPanel VerticalAlignment="Center">
                <Canvas x:Name="TitleCanvas" Height="14" ClipToBounds="True">
                    <TextBlock x:Name="TxtTitle" Canvas.Top="0"
                               Text="Not playing" FontSize="11" FontWeight="SemiBold"
                               Foreground="White" TextWrapping="NoWrap">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="TxtTitleTransform" X="0" Y="0"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Canvas>
                <TextBlock x:Name="TxtArtist" Text="" FontSize="9"
                           Foreground="#888888" TextTrimming="CharacterEllipsis"
                           Margin="0,1,0,0"/>
            </StackPanel>
        </Border>

        <!-- Media Buttons -->
        <StackPanel Grid.Column="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0">
            <Button x:Name="BtnPrev" Content="&#x23EE;" Style="{StaticResource MediaBtn}"
                    Click="BtnPrev_Click" ToolTip="Previous"/>
            <Button x:Name="BtnPlay" Content="&#x25B6;" Style="{StaticResource MediaBtn}"
                    FontSize="12" Width="24" Click="BtnPlay_Click" ToolTip="Play/Pause"/>
            <Button x:Name="BtnNext" Content="&#x23ED;" Style="{StaticResource MediaBtn}"
                    Click="BtnNext_Click" ToolTip="Next"/>
        </StackPanel>

        <!-- Volume icon (click → toggle drawer, scroll → volume) -->
        <Grid x:Name="VolContainer" Grid.Column="3" Background="Transparent"
              MouseWheel="Volume_MouseWheel" MouseLeftButtonUp="Volume_Click"
              Cursor="Hand" Margin="2,0,4,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtVolIcon" Text="&#x1F50A;" Foreground="#BBBBBB"
                           FontSize="11" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtVolPercent" Text="" Foreground="#666666"
                           FontSize="7" HorizontalAlignment="Center" Margin="0,-1,0,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
