<Window x:Class="TaskbarMusicWidget.Widgets.MusicDrawer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Focusable="False"
        IsHitTestVisible="True">
    <Window.Resources>

        <!-- Accent brush — updated dynamically from album art -->
        <SolidColorBrush x:Key="DrawerAccentBrush" Color="#CC6EE7F5"/>

        <!-- Control button (same small style as widget) -->
        <Style x:Key="MediaBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="5" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#65FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bigger drawer button -->
        <Style x:Key="DrawerBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#65FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 10s seek button -->
        <Style x:Key="SeekBtn" TargetType="Button" BasedOn="{StaticResource DrawerBtn}">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Foreground" Value="#888888"/>
        </Style>

        <!-- Slider with accent fill -->
        <Style x:Key="DrawerSlider" TargetType="Slider">
            <Setter Property="MinHeight" Value="16"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <!-- Arka plan çizgisi -->
                            <Border Height="4" Background="#33FFFFFF" CornerRadius="2" VerticalAlignment="Center"/>
                            
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <!-- Dolu kısım (Accent) -->
                                                <Border Height="4" Background="{DynamicResource DrawerAccentBrush}" CornerRadius="2" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12" Height="12">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="White">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.4" Direction="270"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Slide-up wrapper -->
    <Border x:Name="SlideRoot">
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" Y="0"/>
        </Border.RenderTransform>

        <!-- Card container -->
        <Grid x:Name="DrawerCard" Margin="0">
            <!-- Gölge katmanı (BlurEffect'in bozulmaması için ClipToBounds dışına alındı) -->
            <Border Background="Black" CornerRadius="10,10,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.95" Color="Black"/>
                </Border.Effect>
            </Border>

            <!-- İçerik katmanı (Kenarları yuvarlatılmış ve kırpılmış) -->
            <Border CornerRadius="10,10,0,0" ClipToBounds="True">
                <Border.Background>
                    <SolidColorBrush Color="#FF080808"/>
                </Border.Background>

                <Grid>
                    <!-- ① Blurred album art -->
                    <Image x:Name="AlbumBg" Stretch="UniformToFill"
                           Opacity="0.50" Margin="-40"
                           RenderOptions.BitmapScalingMode="LowQuality">
                        <Image.Effect>
                            <!-- RenderingBias=Performance yazılımsal render modunda çalışmasını garanti eder -->
                            <BlurEffect Radius="30" RenderingBias="Performance"/>
                        </Image.Effect>
                    </Image>

                    <!-- ② Colour tint driven by dominant album colour -->
                    <Border x:Name="TintLayer">
                        <Border.Background>
                            <SolidColorBrush x:Name="TintBrush" Color="#40000000"/>
                        </Border.Background>
                    </Border>

                    <!-- ③ Readability scrim: top lighter, bottom darker -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#60000000" Offset="0"/>
                                <GradientStop Color="#CC000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                <!-- ④ Content -->
                <Grid Margin="14,11,14,12" MouseEnter="Content_MouseEnter"
                      MouseLeave="Content_MouseLeave">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Track info + mute -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>   <!-- Timeline -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>   <!-- Controls -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>   <!-- Volume -->
                    </Grid.RowDefinitions>

                    <!-- ── Row 0: Track info ───────────────────────── -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtTitle" Text="Not playing"
                                       Foreground="White" FontSize="12" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="TxtArtist" Text=""
                                       Foreground="#CCCCCC" FontSize="9" Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="8,0,0,0">
                            <Button x:Name="BtnMute" Width="20" Height="20"
                                    Style="{StaticResource MediaBtn}"
                                    Click="BtnMute_Click">
                                <TextBlock x:Name="TxtMuteIcon" Text="&#x1F50A;" FontSize="10"/>
                            </Button>
                            <TextBlock x:Name="TxtVolVal" Text="50" Foreground="#AAAAAA"
                                       FontSize="9" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- ── Row 2: Timeline ─────────────────────────── -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock x:Name="TxtPosition" Text="0:00"
                                       Foreground="#AAAAAA" FontSize="8" HorizontalAlignment="Left"/>
                            <TextBlock x:Name="TxtDuration" Text="0:00"
                                       Foreground="#AAAAAA" FontSize="8" HorizontalAlignment="Right"/>
                        </Grid>
                        <Slider x:Name="SldTimeline" Grid.Row="2"
                                Minimum="0" Maximum="100" Value="0"
                                Style="{StaticResource DrawerSlider}"
                                IsMoveToPointEnabled="True"
                                PreviewMouseLeftButtonDown="SldTimeline_Down"
                                PreviewMouseLeftButtonUp="SldTimeline_Up"
                                ValueChanged="SldTimeline_Changed"/>
                    </Grid>

                    <!-- ── Row 4: Playback controls ────────────────── -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnSeekBack" Grid.Column="1"
                                Style="{StaticResource SeekBtn}" Click="BtnSeekBack_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x21BA;" FontSize="11" Margin="0,0,1,0"/>
                                <TextBlock Text="10" FontSize="8" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnPrev" Grid.Column="2"
                                Content="&#x23EE;" Style="{StaticResource DrawerBtn}"
                                Click="BtnPrev_Click"/>

                        <Button x:Name="BtnPlay" Grid.Column="3"
                                Content="&#x25B6;" Style="{StaticResource DrawerBtn}"
                                FontSize="17" Width="40" Height="40"
                                Click="BtnPlay_Click"/>

                        <Button x:Name="BtnNext" Grid.Column="4"
                                Content="&#x23ED;" Style="{StaticResource DrawerBtn}"
                                Click="BtnNext_Click"/>

                        <Button x:Name="BtnSeekFwd" Grid.Column="5"
                                Style="{StaticResource SeekBtn}" Click="BtnSeekFwd_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="10" FontSize="8" VerticalAlignment="Center"/>
                                <TextBlock Text="&#x21BB;" FontSize="11" Margin="1,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- ── Row 6: Volume (full width) ──────────────── -->
                    <Grid Grid.Row="6" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#x1F50A;" Foreground="#888888" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="SldVolume" Grid.Column="1"
                                Style="{StaticResource DrawerSlider}"
                                Minimum="0" Maximum="100" Value="50"
                                VerticalAlignment="Center"
                                IsMoveToPointEnabled="True"
                                ValueChanged="SldVolume_Changed"/>
                    </Grid>
                </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
