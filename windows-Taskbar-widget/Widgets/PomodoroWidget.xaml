<UserControl x:Class="TaskbarMusicWidget.Widgets.PomodoroWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="38"
             PreviewMouseRightButtonUp="Pomodoro_RightClick">

    <UserControl.Resources>
        <Style x:Key="CtrlBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="5" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#60FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>



    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="36"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="58"/>
        </Grid.ColumnDefinitions>

        <!-- Circular progress arc -->
        <Grid Grid.Column="0" Margin="3">
            <Canvas Width="30" Height="30"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Background ring -->
                <Ellipse Width="30" Height="30" Stroke="#333333" StrokeThickness="3" Fill="Transparent"/>
                <!-- Progress arc -->
                <Path x:Name="ProgressArc" Stroke="#EF4444" StrokeThickness="3"
                      Fill="Transparent"/>

                <!-- Session count -->
                <TextBlock x:Name="TxtSession" Canvas.Left="0" Canvas.Top="8"
                           Width="30" Text="1" FontSize="9" FontWeight="Bold"
                           Foreground="White" TextAlignment="Center"/>
            </Canvas>
        </Grid>

        <!-- Phase + time display -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0">
            <TextBlock Name="TxtPhase" Text="WORK" FontSize="7" FontWeight="Bold"
                       Foreground="#EF4444" Opacity="0.9" Margin="0,0,0,1"/>
            <TextBlock Name="TxtTime" Text="25:00"
                       FontSize="15" FontWeight="Bold"
                       Foreground="White"
                       FontFamily="Consolas, Courier New"/>
        </StackPanel>

        <!-- Buttons: Play/Pause + Skip -->
        <StackPanel Grid.Column="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0">
            <Button Name="BtnStartPause" Content="▶" Style="{StaticResource CtrlBtn}"
                    Click="BtnStartPause_Click" ToolTip="Start / Pause"/>
            <Button Name="BtnSkip" Content="⏭" Style="{StaticResource CtrlBtn}"
                    Click="BtnSkip_Click" ToolTip="Next Phase"/>
        </StackPanel>
    </Grid>
</UserControl>
