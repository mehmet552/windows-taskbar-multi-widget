<UserControl x:Class="TaskbarMusicWidget.Widgets.TimerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="38">

    <UserControl.Resources>
        <Style x:Key="CtrlBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="5" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#60FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Right-click context menu for presets -->
    <UserControl.ContextMenu>
        <ContextMenu Background="#252525" BorderBrush="#3A3A3A" Foreground="White">
            <ContextMenu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ContextMenu.Resources>
            <MenuItem Header="⏱  1 Minute"  Click="Preset_Click" Tag="00:01:00"/>
            <MenuItem Header="⏱  5 Minutes"  Click="Preset_Click" Tag="00:05:00"/>
            <MenuItem Header="⏱  10 Minutes" Click="Preset_Click" Tag="00:10:00"/>
            <MenuItem Header="⏱  15 Minutes" Click="Preset_Click" Tag="00:15:00"/>
            <MenuItem Header="⏱  25 Minutes" Click="Preset_Click" Tag="00:25:00"/>
            <MenuItem Header="⏱  30 Minutes" Click="Preset_Click" Tag="00:30:00"/>
            <MenuItem Header="⏱  60 Minutes" Click="Preset_Click" Tag="01:00:00"/>
            <Separator Background="#3A3A3A"/>
            <MenuItem Header="✏  Custom Time..." Click="CustomTime_Click"/>
        </ContextMenu>
    </UserControl.ContextMenu>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="36"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="62"/>
        </Grid.ColumnDefinitions>

        <!-- Icon area -->
        <Border Grid.Column="0" Margin="4" CornerRadius="4">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2A1E00" Offset="0"/>
                    <GradientStop Color="#1A1400" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="⏱" FontSize="15"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#F59E0B"/>
        </Border>

        <!-- Time display -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0">
            <TextBlock Name="TxtLabel" Text="TIMER" FontSize="7" FontWeight="Bold"
                       Foreground="#F59E0B" Opacity="0.8" Margin="0,0,0,1"/>

            <TextBlock Name="TxtTime" Text="05:00"
                       FontSize="15" FontWeight="Bold"
                       Foreground="White"
                       FontFamily="Consolas, Courier New"/>
        </StackPanel>

        <!-- Buttons: Play/Pause + Reset -->
        <StackPanel Grid.Column="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0">
            <Button Name="BtnStartPause" Content="▶" Style="{StaticResource CtrlBtn}"
                    Click="BtnStartPause_Click" ToolTip="Start / Pause"/>
            <Button Name="BtnReset" Content="⏹" Style="{StaticResource CtrlBtn}"
                    Click="BtnReset_Click" ToolTip="Reset"/>
        </StackPanel>
    </Grid>
</UserControl>
